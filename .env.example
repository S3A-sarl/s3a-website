# SMTP interne S3A — pour l'envoi des formulaires contact et recrutement
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Optionnel : si le certificat TLS du serveur SMTP couvre un autre nom (SNI)
# Ex. host=mail.s3a.ma mais cert valable pour s3a.ma → SMTP_TLS_SERVERNAME=s3a.ma
# SMTP_TLS_SERVERNAME=
# SMTP_TLS_REJECT_UNAUTHORIZED=true   # mettre à "false" pour ignorer la validation cert (déconseillé)

# Destinataire et expéditeur des emails envoyés depuis le site
CONTACT_TO=s3a-sarl@hotmail.fr
CONTACT_FROM="S3A Site <noreply@s3a.ma>"

# URL canonique (utilisée pour sitemap, OG, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://s3a.ma
